# ──────────────────────────────────────────────────────────────────────────────
# AuraAI Backend — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ──────────────────────────────────────────────────────────────────────────────

# Your Groq API key — https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# AES encryption key for cipher display. Any random string works.
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
FERNET_KEY=your_random_secret_key_here

# Comma-separated frontend URLs allowed to call this backend
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# Groq model (alternatives: llama3-8b-8192, mixtral-8x7b-32768)
GROQ_MODEL=llama3-70b-8192

# Max tokens in AI response
GROQ_MAX_TOKENS=2048

# Set to your Render service URL to enable keep-alive pings
# RENDER_EXTERNAL_URL=https://your-service.onrender.com
